//@version=6

// ============================================================================
// PROFESSIONAL NIFTY/BANKNIFTY AUTOMATED TRADING SYSTEM
// Author: Institutional Trading Specialist (20+ Years Experience)
// Version: 1.0 - Professional Grade
// ============================================================================

indicator(
    title="Professional NIFTY Trading System v1.0",
    shorttitle="PROF-NITS",
    overlay=true
)

// ============================================================================
// INPUT SETTINGS - PROFESSIONAL CONFIGURATION
// ============================================================================

group_main = "TRADING PARAMETERS"
i_enableSystem = input.bool(true, "Enable Trading System", group=group_main)
i_showDashboard = input.bool(true, "Show Dashboard", group=group_main)
i_showLevels = input.bool(true, "Show Support/Resistance", group=group_main)

group_levels = "SUPPORT/RESISTANCE LEVELS"
i_lookbackPeriod = input.int(20, "Lookback Period (Candles)", minval=5, maxval=100, group=group_levels)
i_atrMultiplier = input.float(1.5, "ATR Multiplier for S/R", minval=0.5, maxval=3.0, group=group_levels)

group_volume = "VOLUME PROFILE SETTINGS"
i_volProfileLength = input.int(50, "Volume Profile Length", minval=20, maxval=100, group=group_volume)
i_pocThreshold = input.float(0.7, "POC Significance %", minval=0.5, maxval=1.5, group=group_volume)

group_vix = "VIX FILTER SETTINGS"
i_vixLow = input.float(12.0, "VIX Low (No Trade Below)", minval=5.0, maxval=15.0, group=group_vix)
i_vixMid = input.float(20.0, "VIX Mid (Normal Trading)", minval=15.0, maxval=25.0, group=group_vix)
i_vixHigh = input.float(30.0, "VIX High (Elevated Risk)", minval=25.0, maxval=50.0, group=group_vix)

group_signals = "SIGNAL SETTINGS"
i_signalStrength = input.int(3, "Signal Strength (1-5)", minval=1, maxval=5, group=group_signals)
i_confirmationBars = input.int(2, "Confirmation Bars", minval=1, maxval=5, group=group_signals)

group_risk = "RISK MANAGEMENT"
i_maxRiskPercent = input.float(2.0, "Max Risk %", minval=0.5, maxval=5.0, group=group_risk)
i_profitTarget = input.float(3.0, "Profit Target %", minval=1.0, maxval=10.0, group=group_risk)

group_alerts = "ALERTS"
i_enableAlerts = input.bool(true, "Enable Alerts", group=group_alerts)
i_alertSound = input.bool(false, "Alert Sound", group=group_alerts)

// ============================================================================
// GLOBAL VARIABLES - STATE MANAGEMENT
// ============================================================================

var float[] recentHighs = array.new<float>()
var float[] recentLows = array.new<float>()
var float[] volumeArray = array.new<float>()

var float r2Level = na
var float r1Level = na
var float pocLevel = na
var float s1Level = na
var float s2Level = na

var bool inLongTrade = false
var bool inShortTrade = false
var float entryPrice = na

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

// Calculate ATR
f_atr(int length) =>
    ta.atr(length)

// Get VIX value
f_getVIX() =>
    request.security("NSE:INDIAVIX", "D", close)

// VIX classification
f_getVIXRegime() =>
    float vix = f_getVIX()
    string regime = "Normal"
    
    if vix < i_vixLow
        regime := "Low Volatility (Caution)"
    else if vix >= i_vixLow and vix < i_vixMid
        regime := "Normal"
    else if vix >= i_vixMid and vix < i_vixHigh
        regime := "Elevated"
    else
        regime := "High Volatility (Risk)"
    
    regime

// ============================================================================
// SUPPORT & RESISTANCE CALCULATION (20+ Year Trader Levels)
// ============================================================================

// Calculate R2 (Second Resistance)
f_calculateR2(float h, float l, float c) =>
    h + (2 * (c - l))

// Calculate R1 (First Resistance)
f_calculateR1(float h, float l, float c) =>
    (2 * c) - l

// Calculate S1 (First Support)
f_calculateS1(float h, float l, float c) =>
    (2 * c) - h

// Calculate S2 (Second Support)
f_calculateS2(float h, float l, float c) =>
    l - (2 * (h - c))

// Pivot Point (POC approximation)
f_calculatePOC(float h, float l, float c) =>
    (h + l + c) / 3

// Update SR levels daily
f_updateSRLevels() =>
    float dayHigh = ta.highest(high, i_lookbackPeriod)
    float dayLow = ta.lowest(low, i_lookbackPeriod)
    float dayClose = close[1]
    
    float poc = f_calculatePOC(dayHigh, dayLow, dayClose)
    float r2 = f_calculateR2(dayHigh, dayLow, dayClose)
    float r1 = f_calculateR1(dayHigh, dayLow, dayClose)
    float s1 = f_calculateS1(dayHigh, dayLow, dayClose)
    float s2 = f_calculateS2(dayHigh, dayLow, dayClose)
    
    [r2, r1, poc, s1, s2]

// ============================================================================
// VOLUME PROFILE ANALYSIS
// ============================================================================

// Calculate volume-weighted price
f_getVWAP() =>
    ta.vwap(close)

// Volume trend analysis
f_getVolumeProfile() =>
    string profile = "Normal"
    float avgVol = ta.sma(volume, i_volProfileLength)
    float volRatio = volume / avgVol
    
    if volRatio > 1.5
        profile := "Strong Volume"
    else if volRatio < 0.7
        profile := "Weak Volume"
    else
        profile := "Normal Volume"
    
    profile

// Volume confirmation for signals
f_hasVolumeConfirmation() =>
    float avgVol = ta.sma(volume, i_volProfileLength)
    volume > avgVol * 1.2

// ============================================================================
// CANDLESTICK PATTERN DETECTION
// ============================================================================

// Bullish patterns
f_isBullishEngulfing() =>
    close[1] > open[1] and close > open and 
    open <= close[1] and close > open[1] and
    volume > ta.sma(volume, 20) * 1.1

// Bearish patterns
f_isBearishEngulfing() =>
    close[1] < open[1] and close < open and
    open >= close[1] and close < open[1] and
    volume > ta.sma(volume, 20) * 1.1

// Inside bar (consolidation)
f_isInsideBar() =>
    high < high[1] and low > low[1]

// ============================================================================
// SIGNAL GENERATION ENGINE - PROFESSIONAL GRADE
// ============================================================================

// BUY Signal with 20+ Year Strategy
f_generateBuySignal() =>
    bool buySignal = false
    
    [r2, r1, poc, s1, s2] = f_updateSRLevels()
    float vix = f_getVIX()
    string volProfile = f_getVolumeProfile()
    
    // Condition 1: Price near S1 or S2 with strong volume
    if (close >= s2 and close <= s1) and f_hasVolumeConfirmation() and vix > i_vixLow
        // Condition 2: Candlestick confirmation
        if f_isBullishEngulfing() or (close > open and high == high[0])
            // Condition 3: No trade zone check
            if not f_isInNoTradeZone()
                buySignal := true
    
    buySignal

// SELL Signal with 20+ Year Strategy
f_generateSellSignal() =>
    bool sellSignal = false
    
    [r2, r1, poc, s1, s2] = f_updateSRLevels()
    float vix = f_getVIX()
    string volProfile = f_getVolumeProfile()
    
    // Condition 1: Price near R1 or R2 with strong volume
    if (close >= r1 and close <= r2) and f_hasVolumeConfirmation() and vix > i_vixLow
        // Condition 2: Candlestick confirmation
        if f_isBearishEngulfing() or (close < open and low == low[0])
            // Condition 3: No trade zone check
            if not f_isInNoTradeZone()
                sellSignal := true
    
    sellSignal

// EXIT Signal (Take Profit)
f_generateExitSignal(bool isLong) =>
    bool exitSignal = false
    
    [r2, r1, poc, s1, s2] = f_updateSRLevels()
    
    if isLong
        // Exit long when price reaches target or reversal
        if close >= r2 or close <= s1
            exitSignal := true
    else
        // Exit short when price reaches target or reversal
        if close <= s2 or close >= r1
            exitSignal := true
    
    exitSignal

// ============================================================================
// NO TRADE ZONE DETECTION
// ============================================================================

// No trade conditions
f_isInNoTradeZone() =>
    bool noTrade = false
    
    [r2, r1, poc, s1, s2] = f_updateSRLevels()
    float vix = f_getVIX()
    string volProfile = f_getVolumeProfile()
    
    // Low volatility - no directional bias
    if vix < i_vixLow
        noTrade := true
    
    // Weak volume - unreliable signals
    if volProfile == "Weak Volume"
        noTrade := true
    
    // Inside the POC zone - no clear direction
    if close >= (poc * 0.98) and close <= (poc * 1.02)
        noTrade := true
    
    // Between S1 and R1 with indecision
    if f_isInsideBar()
        noTrade := true
    
    noTrade

// ============================================================================
// MAIN CALCULATION LOGIC
// ============================================================================

// Update levels
[r2, r1, poc, s1, s2] = f_updateSRLevels()

// Get signals
bool buySignal = f_generateBuySignal()
bool sellSignal = f_generateSellSignal()
bool isNoTrade = f_isInNoTradeZone()

// Get regime info
float vix = f_getVIX()
string vixRegime = f_getVIXRegime()
string volProfile = f_getVolumeProfile()

// Signal decision
string tradeSignal = "Hold"
if buySignal
    tradeSignal := "BUY"
    inLongTrade := true
    inShortTrade := false
    entryPrice := close
else if sellSignal
    tradeSignal := "SELL"
    inShortTrade := true
    inLongTrade := false
    entryPrice := close

if f_generateExitSignal(inLongTrade) or f_generateExitSignal(inShortTrade)
    tradeSignal := "EXIT"
    inLongTrade := false
    inShortTrade := false

if isNoTrade
    tradeSignal := "NO TRADE"

// ============================================================================
// PLOTTING FUNCTIONS
// ============================================================================

// Plot S/R Levels
if i_showLevels
    // R2 (Red line - top resistance)
    plot(r2, "R2 (2nd Resistance)", color.new(color.red, 30), linewidth=3, style=plot.style_dashed)
    
    // R1 (Orange line - 1st resistance)
    plot(r1, "R1 (Resistance)", color.new(color.orange, 30), linewidth=2, style=plot.style_dashed)
    
    // POC (Blue line - pivot point)
    plot(poc, "POC (Pivot)", color.new(color.blue, 40), linewidth=2, style=plot.style_dashed)
    
    // S1 (Green line - 1st support)
    plot(s1, "S1 (Support)", color.new(color.green, 30), linewidth=2, style=plot.style_dashed)
    
    // S2 (Dark green line - 2nd support)
    plot(s2, "S2 (2nd Support)", color.new(color.green, 50), linewidth=3, style=plot.style_dashed)

// Plot signals
if i_enableSystem
    // BUY Signal
    if buySignal
        plotshape(buySignal, location=location.belowbar, shape=shape.labelup, 
                 color=color.new(color.green, 0), textcolor=color.white, size=size.small, text="BUY")
    
    // SELL Signal
    if sellSignal
        plotshape(sellSignal, location=location.abovebar, shape=shape.labeldown,
                 color=color.new(color.red, 0), textcolor=color.white, size=size.small, text="SELL")
    
    // EXIT Signal
    if tradeSignal == "EXIT"
        plotshape(true, location=location.abovebar, shape=shape.cross,
                 color=color.new(color.yellow, 0), size=size.small, text="EXIT")

// No trade zone background
if isNoTrade
    bgcolor(color.new(color.yellow, 90))

// ============================================================================
// DASHBOARD - PROFESSIONAL DISPLAY
// ============================================================================

if i_showDashboard
    var table dashboard = table.new(position.top_right, 3, 12, 
                                   border_color=color.new(color.gray, 50), border_width=2)
    
    // Header
    table.cell(dashboard, 0, 0, "PROFESSIONAL TRADING SYSTEM", text_color=color.white, 
              bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(dashboard, 1, 0, "Status", text_color=color.white, 
              bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(dashboard, 2, 0, "Value", text_color=color.white, 
              bgcolor=color.new(color.blue, 0), text_size=size.small)
    
    // Trade Signal
    table.cell(dashboard, 0, 1, "Trade Signal", text_color=color.white, 
              bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(dashboard, 1, 1, tradeSignal, 
              text_color=(tradeSignal == "BUY" ? color.green : (tradeSignal == "SELL" ? color.red : 
              (tradeSignal == "NO TRADE" ? color.orange : color.yellow))), text_size=size.small)
    
    // VIX Status
    table.cell(dashboard, 0, 2, "VIX Regime", text_color=color.white, 
              bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(dashboard, 1, 2, vixRegime, text_color=(vix < i_vixMid ? color.green : color.orange),
              text_size=size.small)
    table.cell(dashboard, 2, 2, str.format("{0:.2f}", vix), text_color=color.white, text_size=size.small)
    
    // Volume Profile
    table.cell(dashboard, 0, 3, "Volume Profile", text_color=color.white, 
              bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(dashboard, 1, 3, volProfile, 
              text_color=(volProfile == "Strong Volume" ? color.green : 
              (volProfile == "Weak Volume" ? color.red : color.orange)), text_size=size.small)
    
    // S/R Levels
    table.cell(dashboard, 0, 4, "R2", text_color=color.white, bgcolor=color.new(color.gray, 40))
    table.cell(dashboard, 1, 4, str.format("{0:.2f}", r2), text_color=color.red, text_size=size.small)
    
    table.cell(dashboard, 0, 5, "R1", text_color=color.white, bgcolor=color.new(color.gray, 40))
    table.cell(dashboard, 1, 5, str.format("{0:.2f}", r1), text_color=color.orange, text_size=size.small)
    
    table.cell(dashboard, 0, 6, "POC", text_color=color.white, bgcolor=color.new(color.gray, 40))
    table.cell(dashboard, 1, 6, str.format("{0:.2f}", poc), text_color=color.blue, text_size=size.small)
    
    table.cell(dashboard, 0, 7, "S1", text_color=color.white, bgcolor=color.new(color.gray, 40))
    table.cell(dashboard, 1, 7, str.format("{0:.2f}", s1), text_color=color.green, text_size=size.small)
    
    table.cell(dashboard, 0, 8, "S2", text_color=color.white, bgcolor=color.new(color.gray, 40))
    table.cell(dashboard, 1, 8, str.format("{0:.2f}", s2), text_color=color.new(color.green, 50),
              text_size=size.small)
    
    // Entry Info
    if inLongTrade or inShortTrade
        table.cell(dashboard, 0, 9, "Entry Price", text_color=color.white, 
                  bgcolor=color.new(color.gray, 40), text_size=size.small)
        table.cell(dashboard, 1, 9, str.format("{0:.2f}", entryPrice), text_color=color.white,
                  text_size=size.small)
        
        table.cell(dashboard, 0, 10, "Profit Target", text_color=color.white, 
                  bgcolor=color.new(color.gray, 40), text_size=size.small)
        float target = inLongTrade ? entryPrice * (1 + i_profitTarget/100) : 
                       entryPrice * (1 - i_profitTarget/100)
        table.cell(dashboard, 1, 10, str.format("{0:.2f}", target), text_color=color.green,
                  text_size=size.small)
        
        table.cell(dashboard, 0, 11, "Stop Loss", text_color=color.white, 
                  bgcolor=color.new(color.gray, 40), text_size=size.small)
        float sl = inLongTrade ? entryPrice * (1 - i_maxRiskPercent/100) : 
                   entryPrice * (1 + i_maxRiskPercent/100)
        table.cell(dashboard, 1, 11, str.format("{0:.2f}", sl), text_color=color.red,
                  text_size=size.small)

// ============================================================================
// ALERTS
// ============================================================================

if i_enableAlerts
    if buySignal
        alert("🟢 BUY SIGNAL - Entry at S1/S2 Level | VIX: " + str.format("{0:.2f}", vix), 
             alert.freq_once_per_bar_close)
    
    if sellSignal
        alert("🔴 SELL SIGNAL - Entry at R1/R2 Level | VIX: " + str.format("{0:.2f}", vix), 
             alert.freq_once_per_bar_close)
    
    if tradeSignal == "EXIT"
        alert("🟡 EXIT SIGNAL - Take Profit/Stop Loss Hit", alert.freq_once_per_bar_close)
    
    if isNoTrade
        alert("⚠️ NO TRADE ZONE - Avoid Trading | VIX: " + str.format("{0:.2f}", vix), 
             alert.freq_once_per_bar_close)

// ============================================================================
// END OF INDICATOR
// ============================================================================
